# ─── Supabase (required) ─────────────────────────────────────────────────────
#
# After the Supabase migration the panel uses Supabase Auth (user accounts +
# password) instead of the single ADMIN_PASSWORD env var, and Supabase
# Postgres (`activities_v1`, `usage_snapshots_v1`) instead of local SQLite.

# Project URL — same value goes to NEXT_PUBLIC_SUPABASE_URL so the
# browser-side client can talk to Supabase directly when needed.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Anon key — safe in the browser; gated by RLS policies on Supabase.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Service-role key — server-only. Bypasses RLS. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ─── OpenClaw integration ────────────────────────────────────────────────────

# Base directory the panel reads from. In production, mount the OpenClaw
# data volume read-only at this path.
# OPENCLAW_DIR=/workspace

# Optional override for the workspace subdir (defaults to $OPENCLAW_DIR/workspace).
# OPENCLAW_WORKSPACE=/workspace/workspace

# Gateway API used by the panel (Phase 2). Leave unset to fall back to local
# filesystem reads.
# OPENCLAW_GATEWAY_URL=http://openclaw:64931
# OPENCLAW_GATEWAY_TOKEN=

# ─── Observability ───────────────────────────────────────────────────────────

# Where to append the audit log (JSONL). Stays on the filesystem because
# append-only is cheap and the file is bind-mounted into a persistent
# volume by the compose file.
# AUDIT_LOG_PATH=/app/data/audit.log

# ─── Branding (customize for your instance) ──────────────────────────────────

NEXT_PUBLIC_AGENT_NAME=Mission Control
NEXT_PUBLIC_AGENT_EMOJI=🦞
NEXT_PUBLIC_AGENT_DESCRIPTION=Your AI co-pilot, powered by OpenClaw
NEXT_PUBLIC_AGENT_LOCATION=
NEXT_PUBLIC_BIRTH_DATE=
NEXT_PUBLIC_AGENT_AVATAR=
NEXT_PUBLIC_OWNER_USERNAME=your-username
NEXT_PUBLIC_OWNER_EMAIL=your-email@example.com
NEXT_PUBLIC_OWNER_COLLAB_EMAIL=collabs@example.com
NEXT_PUBLIC_TWITTER_HANDLE=@username
NEXT_PUBLIC_COMPANY_NAME=MISSION CONTROL, INC.
NEXT_PUBLIC_APP_TITLE=Mission Control
